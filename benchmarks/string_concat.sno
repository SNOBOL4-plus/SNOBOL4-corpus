* string_concat.sno
* Bottleneck: string allocation and GC pressure (O(n^2) copies).
* Append one char 2000 times. Expected SIZE: 2000
    &TRIM = 1
    &STLIMIT = 10000000
    T1 = TIME()
    S = ''
    N = 0
LOOP    N = LT(N, 2000) N + 1          :F(DONE)
    S = S 'x'                          :(LOOP)
DONE    T2 = TIME()
    OUTPUT = "result: " SIZE(S)
    OUTPUT = "ms: " (T2 - T1)
END
