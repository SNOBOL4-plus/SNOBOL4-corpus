* string_manip.sno
* Bottleneck: string function dispatch and string allocation.
* Runs REPLACE, SIZE on a sentence string 500 times.
    &TRIM = 1
    &STLIMIT = 10000000
    T1 = TIME()
    ITER = 0
LOOP    ITER = LT(ITER, 500) ITER + 1      :F(DONE)
    S = 'The quick brown fox jumps over the lazy dog'
    S = REPLACE(S, 'aeiou', '*****')
    N = SIZE(S)
    :(LOOP)
DONE    T2 = TIME()
    OUTPUT = "result: " N
    OUTPUT = "ms: " (T2 - T1)
END
